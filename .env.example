# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/nat_platform

# Individual PostgreSQL settings (optional if DATABASE_URL is set)
PGHOST=localhost
PGPORT=5432
PGUSER=your_username
PGPASSWORD=your_password
PGDATABASE=nat_platform

# Session Configuration
# Generate a random string for session encryption
SESSION_SECRET=your-random-session-secret-here

# AI Integration (Anthropic Claude)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI Integration (OpenAI) - Optional
# Get your API key from https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# Azure DevOps Integration (Optional)
# For importing user stories from Azure DevOps
ADO_ORGANIZATION=your-organization
ADO_PROJECT=your-project
ADO_PAT=your-personal-access-token

# Jira Integration (Optional)
# For importing user stories from Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ── Email / SMTP (for welcome emails on user creation) ────────────────────────
# Gmail: use smtp.gmail.com + an App Password (NOT your login password)
# Generate App Password: https://myaccount.google.com/apppasswords (needs 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=ASTRA Platform

# Public URL shown in email login button (no trailing slash)
APP_URL=http://localhost:5000

# Application Settings
NODE_ENV=development
PORT=5000

# ── Azure App Service — REQUIRED Application Settings ─────────────────────────
# Set these in Portal → Configuration → Application Settings (NOT in .env):
#
#   PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = 1
#     Remote agent handles browser execution — no browser needed on the server
#
#   WEBSITE_NODE_DEFAULT_VERSION = ~20
#     Use Node.js 20 LTS
#
#   SCM_DO_BUILD_DURING_DEPLOYMENT = true
#     Run npm install + npm run build automatically on each deploy
#
#   NODE_ENV = production
#   SESSION_SECRET = <long random string>
#   DATABASE_URL = <Azure PostgreSQL connection string with ?sslmode=require>
#   ANTHROPIC_API_KEY = <your key>

# ── Azure App Service — Portal Settings (General Settings tab) ─────────────────
#   Web Sockets          → ON   (required for Chrome extension + remote agent)
#   HTTP Version         → 2.0
#   Always On            → ON   (prevents cold starts dropping WebSocket connections)

# Skip Playwright browser download on Azure (browser runs on remote agent machine)
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# ── Recording Mode ─────────────────────────────────────────────────────────────
#
# NAT_ENV=azure
#   Force Azure/cloud recording mode even when running locally.
#   In this mode, POST /api/recorder/playwright-start delegates to the Remote Agent
#   instead of launching Playwright on the server.
#   Detected automatically on Azure App Service via WEBSITE_INSTANCE_ID.
#   Set this manually only for local cloud-simulation testing.
#
# NAT_ENV=azure  ← uncomment to test agent-delegated recording locally

# ── Remote Agent — how to start it for Azure recording ─────────────────────────
#
#   cd remote-agent
#   SERVER_URL=wss://nat20-astra.azurewebsites.net/ws/execution-agent npx tsx agent.ts
#
#   The agent connects to /ws/execution-agent on the Azure server.
#   When the user clicks "Record with Playwright" in the Azure UI, the server
#   sends start_recording to the agent, which opens a headed Chromium window
#   on the local machine. Events flow back to Azure via the same WebSocket.

