<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service (Windows) — web.config
  - Routes all HTTP requests to Node.js via iisnode
  - Enables WebSocket support for /ws/recorder and /ws/execution-agent
  - Serves static files from dist/public directly via IIS (faster)
-->
<configuration>
  <system.webServer>

    <!-- Enable WebSockets -->
    <webSocket enabled="true" />

    <!-- iisnode: hand off Node.js requests -->
    <handlers>
      <add name="iisnode" path="dist/index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- WebSocket: recorder (Chrome Extension) -->
        <rule name="WebSocket Recorder" stopProcessing="true">
          <match url="^ws/recorder$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- WebSocket: remote execution agent -->
        <rule name="WebSocket Agent" stopProcessing="true">
          <match url="^ws/execution-agent$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- Static assets: serve from dist/public directly -->
        <rule name="Static Assets" stopProcessing="true">
          <match url="^(assets|icons|favicon\.ico)(.*)" />
          <action type="Rewrite" url="dist/public/{R:0}" />
        </rule>

        <!-- Everything else: Node.js -->
        <rule name="Node App" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="dist/index.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
